# Copy this file to config.local and fill in real values.
# config.local is gitignored — never commit it.

HOST=your-server-ip
USER=debian
KEY=$HOME/.ssh/your-key.pem
ADMIN_KEY=your-secret-admin-key-here
RELAY_KEY=your-secret-relay-key-here

# Service ports (behind nginx reverse proxy on port 80).
WORLDSIM_PORT=8080
RELAY_PORT=8081

# Phase 4: LLM & External Entropy
ANTHROPIC_API_KEY=your-anthropic-api-key
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_LOCATION=San Diego,US
RANDOM_ORG_API_KEY=your-random-org-api-key

# Frontend CORS — comma-separated allowed origins
CORS_ORIGINS=https://crossworlds.xyz,https://www.crossworlds.xyz

# Gardener — autonomous world steward
GARDENER_INTERVAL=360

# Go GC target percentage (lower = more frequent GC, less peak RSS)
GOGC=50

# Phase 1.4 — Off-server backup (S3)
# All four below are required to enable S3 upload of daily snapshots.
# If S3_BUCKET is unset, the worldsim-backup-s3 timer stays disabled and
# only the local on-server backup runs.
#
# Setup steps:
#   1. From your laptop with admin AWS credentials, run:
#        export AWS_ACCESS_KEY_ID=AKIA... AWS_SECRET_ACCESS_KEY=...
#        export S3_BUCKET=your-globally-unique-bucket-name
#        ./deploy/setup-s3-bucket.sh
#      This creates the bucket, blocks public access, enables versioning,
#      and attaches a 30-day lifecycle expiry rule.
#   2. In the AWS console, create a dedicated IAM user with PutObject-only
#      permission on your bucket (policy is printed by setup-s3-bucket.sh).
#   3. Drop that user's access key + secret here as the *_BACKUP_* vars.
#   4. Run ./deploy/deploy.sh. The timer activates automatically.
S3_BUCKET=
S3_BACKUP_ACCESS_KEY_ID=
S3_BACKUP_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Optional overrides:
# S3_PREFIX=daily        # key prefix; default "daily" matches the lifecycle rule
# S3_STORAGE_CLASS=STANDARD_IA  # cheaper for rarely-read backups
