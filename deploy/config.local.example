# Copy this file to config.local and fill in real values.
# config.local is gitignored — never commit it.

HOST=your-server-ip
USER=debian
KEY=$HOME/.ssh/your-key.pem
ADMIN_KEY=your-secret-admin-key-here
RELAY_KEY=your-secret-relay-key-here

# Service ports (behind nginx reverse proxy on port 80).
WORLDSIM_PORT=8080
RELAY_PORT=8081

# Phase 4: LLM & External Entropy
ANTHROPIC_API_KEY=your-anthropic-api-key
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_LOCATION=San Diego,US
RANDOM_ORG_API_KEY=your-random-org-api-key

# LLM provider chain (2026-06-18). Calls try the providers in LLM_PROVIDERS
# order until one succeeds. Put a cheap provider first to cut cost; later
# providers cover failures (Anthropic's monthly spend cap trips every call with
# a 400 until the 1st of next month). A provider that returns a usage/quota cap
# error is cooled down 30 min and skipped, then re-probed — so the chain
# auto-returns to it once its cap resets.
#
#   LLM_PROVIDERS: ordered CSV of: anthropic | deepseek | xai | venice | custom
#                  (default when unset: anthropic)
#   Each provider reads its own key env var; model is overridable per provider.
#
#   provider   key env            default endpoint / model                       model override
#   anthropic  ANTHROPIC_API_KEY  (above) / claude-haiku-4-5-20251001            ANTHROPIC_MODEL
#   deepseek   DEEPSEEK_API_KEY   api.deepseek.com/chat/completions / deepseek-chat   DEEPSEEK_MODEL
#   xai        XAI_API_KEY        api.x.ai/v1/chat/completions / grok-3          XAI_MODEL
#   venice     VENICE_API_KEY     api.venice.ai/api/v1/chat/completions / llama-3.3-70b  VENICE_MODEL
#   custom     CUSTOM_API_KEY     CUSTOM_BASE_URL (required) / CUSTOM_MODEL (required)
#
# Cost-saving example — DeepSeek primary, Anthropic only as backup:
#   LLM_PROVIDERS=deepseek,anthropic
#   DEEPSEEK_API_KEY=sk-...
# Or DeepSeek-only (omit anthropic from the chain):
#   LLM_PROVIDERS=deepseek
LLM_PROVIDERS=
DEEPSEEK_API_KEY=
XAI_API_KEY=
VENICE_API_KEY=
# Optional per-provider model overrides:
# ANTHROPIC_MODEL=
# DEEPSEEK_MODEL=
# XAI_MODEL=
# VENICE_MODEL=
# Custom OpenAI-compatible endpoint (only if "custom" is in LLM_PROVIDERS):
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=
# CUSTOM_MODEL=

# Frontend CORS — comma-separated allowed origins
CORS_ORIGINS=https://crossworlds.xyz,https://www.crossworlds.xyz

# Gardener — autonomous world steward
GARDENER_INTERVAL=360

# Go GC target percentage (lower = more frequent GC, less peak RSS)
GOGC=50

# Phase 1.4 — Off-server backup (S3)
# All four below are required to enable S3 upload of daily snapshots.
# If S3_BUCKET is unset, the worldsim-backup-s3 timer stays disabled and
# only the local on-server backup runs.
#
# Setup steps:
#   1. From your laptop with admin AWS credentials, run:
#        export AWS_ACCESS_KEY_ID=AKIA... AWS_SECRET_ACCESS_KEY=...
#        export S3_BUCKET=your-globally-unique-bucket-name
#        ./deploy/setup-s3-bucket.sh
#      This creates the bucket, blocks public access, enables versioning,
#      and attaches a 30-day lifecycle expiry rule.
#   2. In the AWS console, create a dedicated IAM user with PutObject-only
#      permission on your bucket (policy is printed by setup-s3-bucket.sh).
#   3. Drop that user's access key + secret here as the *_BACKUP_* vars.
#   4. Run ./deploy/deploy.sh. The timer activates automatically.
S3_BUCKET=
S3_BACKUP_ACCESS_KEY_ID=
S3_BACKUP_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Optional overrides:
# S3_PREFIX=daily        # key prefix; default "daily" matches the lifecycle rule
# S3_STORAGE_CLASS=STANDARD_IA  # cheaper for rarely-read backups
